# Build output
build/
build*/
cache/
cache_art.jpg
.vscode/

# Compiled artifacts (sources are tracked; binaries are built, never committed)
*.o
*.obj
*.a
*.exe
*.dll
*.so
*.pdb
*.ilk

# Runtime logs (curated reference rip logs live in docs/samples/, tracked)
logs/

# Release / dev-build staging (built by the release process, not tracked)
binary-dev/

# Local runtime config (holds real API keys) — NEVER track. The app writes
# remoct.conf/theme.conf to cwd when the config dir isn't resolvable, so a
# test/app run from the repo root can drop one here.
remoct.conf
theme.conf

# App icon asset (local, not tracked). CMake conditionally embeds icon/remoct.ico
# as the exe's first icon when present (Explorer/taskbar/shortcut + wingui window).
# remoct_logo.jpg IS shipped though — it's the app logo, used as the radio-art floor.
icon/*
!icon/remoct_logo.jpg
